	meter {
		width: 300px;
		height: 25px;
	}
	meter::-webkit-meter-bar {
	backgroung: #ddd ;
	border-radius: 5px;
	}
	meter::-webkit-meter-bar-optimum-value {
	</style>
	
	
</body>
